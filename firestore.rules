rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Families (backup data) ──
    // Document ID = backup code. Any authenticated user with the code can read/write.
    // This is intentional — the backup code IS the auth for family sync.
    match /families/{code} {
      allow read, write: if request.auth != null;
    }

    // ── UID to Backup mapping ──
    // Each user can only read/write their own document (keyed by UID).
    match /uid_to_backup/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Usernames ──
    // Anyone authenticated can read (to check availability).
    // Anyone authenticated can create/update (to claim a username).
    match /usernames/{username} {
      allow read, write: if request.auth != null;
    }

    // ── Child Sync Codes ──
    // Any authenticated user can read/write (code is the auth).
    match /child_syncs/{code} {
      allow read, write: if request.auth != null;
    }

    // ── Child Code Map (legacy) ──
    match /child_code_map/{childId} {
      allow read, write: if request.auth != null;
    }

    // ── FCM Tokens ──
    // Each user can only manage their own push tokens.
    match /fcm_tokens/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── User Activity ──
    // Each user can only manage their own activity doc.
    match /user_activity/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Carer Logs ──
    // Readable/writable by anyone authenticated (carer uses a shared link).
    match /carer_logs/{docId} {
      allow read, write: if request.auth != null;
    }

  }
}
