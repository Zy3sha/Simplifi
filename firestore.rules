rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── families/{code} ──
    // Baby data shared between partners via backup code
    // Field validation: children must be a string under 5MB
    match /families/{familyCode} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.data.keys().hasOnly(['children', 'updatedAt', 'updatedBy', 'writeToken'])
        && request.resource.data.children is string
        && request.resource.data.children.size() < 5000000;
    }

    // ── usernames/{username} ──
    // Maps username to family code + auth hashes
    match /usernames/{username} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && username.size() >= 3
        && username.size() <= 30;
      allow update: if request.auth != null;
    }

    // ── uid_to_backup/{uid} ──
    // Maps anonymous UID to backup code — only owner can read/write
    match /uid_to_backup/{uid} {
      allow read, write: if request.auth != null
        && request.auth.uid == uid;
    }

    // ── child_syncs/{code} ──
    match /child_syncs/{code} {
      allow read, write: if request.auth != null;
    }

    // ── adminUIDs/{uid} ──
    // Admin whitelist — anyone can check, nobody can modify via client
    match /adminUIDs/{uid} {
      allow read: if true;
      allow write: if false;
    }

    // ── feedback/{doc} ──
    match /feedback/{doc} {
      allow read: if true;
      allow write: if request.auth != null;

      match /active/responses/{r} {
        allow create: if request.auth != null;
        allow read: if isAdmin();
        allow update, delete: if false;
      }
    }

    // ── Helper function ──
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/adminUIDs/$(request.auth.uid));
    }

    // ── Deny everything else ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
