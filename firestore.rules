rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helpers
    function signedIn() {
      return request.auth != null;
    }
    function underSizeLimit() {
      // Hard cap per-document write size (1 MB) to prevent bill inflation / DoS.
      return request.resource.size() < 1048576;
    }

    // ── Families (backup data) ──
    // Document ID = backup code. The code IS the shared secret.
    // - get: allowed (need the code to read)
    // - list: DENIED (no enumeration of all families)
    // - create/update: allowed, size-limited
    // - delete: DENIED (protect against accidental or malicious wipes)
    match /families/{code} {
      allow get: if signedIn();
      allow list: if false;
      allow create, update: if signedIn() && underSizeLimit();
      allow delete: if false;

      // Any nested data the family writes (e.g. entries subcollections) follows same model.
      match /{path=**} {
        allow get: if signedIn();
        allow list: if false;
        allow create, update: if signedIn() && underSizeLimit();
        allow delete: if signedIn();
      }
    }

    // ── UID to Backup mapping ──
    // Strictly per-user. Only the owning UID can read/write.
    match /uid_to_backup/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid && underSizeLimit();
    }

    // ── Usernames ──
    // Keep list allowed (password recovery queries by recoveryEmail).
    // Cap document size to limit abuse.
    // NOTE: username takeover is still possible at the app layer — tracked as
    // follow-up work (needs claimedByUid + server-side enforcement).
    match /usernames/{username} {
      allow get, list: if signedIn();
      allow create, update: if signedIn() && underSizeLimit();
      allow delete: if false;
    }

    // ── Child Sync Codes ──
    // Code = shared secret. Prevent enumeration.
    match /child_syncs/{code} {
      allow get: if signedIn();
      allow list: if false;
      allow create, update: if signedIn() && underSizeLimit();
      allow delete: if false;
    }

    // ── Child Code Map (legacy) ──
    match /child_code_map/{childId} {
      allow get: if signedIn();
      allow list: if false;
      allow create, update: if signedIn() && underSizeLimit();
      allow delete: if false;
    }

    // ── FCM Tokens ──
    match /fcm_tokens/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid && underSizeLimit();
    }

    // ── User Activity ──
    match /user_activity/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid && underSizeLimit();
    }

    // ── Carer Logs ──
    // Structure is carer_logs/{backupCode}/entries/{id} and carer_logs/{backupCode}/_meta/session.
    // Recursive match ensures nested docs are covered. No list (prevents enumeration).
    match /carer_logs/{code} {
      allow get: if signedIn();
      allow list: if false;
      allow create, update: if signedIn() && underSizeLimit();
      allow delete: if signedIn();

      match /{path=**} {
        allow get: if signedIn();
        allow list: if signedIn(); // app queries entries subcollection
        allow create, update: if signedIn() && underSizeLimit();
        allow delete: if signedIn();
      }
    }

    // ── Shared Memory Albums ──
    // Public read by link (anyone can view), authenticated write, size-limited.
    match /shared_albums/{albumId} {
      allow get: if true;
      allow list: if false;
      allow create, update: if signedIn() && underSizeLimit();
      allow delete: if signedIn();
    }
  }
}
