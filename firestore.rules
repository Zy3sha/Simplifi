rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Families (baby data) ──
    // GET only (no list/enumerate). You must know the code to access.
    match /families/{code} {
      allow get: if request.auth != null;
      allow list: if false;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAny(['children']);
      allow update: if request.auth != null
        && request.resource.data.keys().hasAny(['children']);
      allow delete: if false;
    }

    // ── Carer Token Lookup ──
    // Maps CT tokens to backup codes. GET only (know token = access).
    match /carer_tokens/{token} {
      allow get: if request.auth != null;
      allow list: if false;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    // ── UID to Backup mapping ──
    // Locked to own UID only
    match /uid_to_backup/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Usernames ──
    // GET only (check if username exists). No list/enumerate.
    match /usernames/{username} {
      allow get: if request.auth != null;
      allow list: if false; // cannot enumerate all usernames
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // ── Child Sync Codes ──
    // GET only. No list.
    match /child_syncs/{code} {
      allow get: if request.auth != null;
      allow list: if false;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    // ── Child Code Map (legacy) ──
    match /child_code_map/{childId} {
      allow get: if request.auth != null;
      allow list: if false;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    // ── FCM Tokens ──
    match /fcm_tokens/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── User Activity ──
    match /user_activity/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // ── Carer Logs ──
    // GET only on parent doc. Entries subcollection open for carers.
    match /carer_logs/{code} {
      allow get: if request.auth != null;
      allow list: if false;
      allow create, update: if request.auth != null;
      allow delete: if false;

      match /entries/{entryId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update: if request.auth != null;
        allow delete: if request.auth != null;
      }
    }

    // ── Block everything else ──
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
