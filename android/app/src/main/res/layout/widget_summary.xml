<?xml version="1.0" encoding="utf-8"?>
<!-- OBubba Widget — dark glass design matching iOS Live Activity -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:gravity="center_vertical"
    android:background="@drawable/widget_bg_gradient">

    <!-- Row 1: Baby name + timer/prediction pill -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_baby_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Baby"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/widget_text_primary"
            android:fontFamily="sans-serif-medium" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end|center_vertical"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/widget_timer_pill"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp">

                <TextView
                    android:id="@+id/tv_timer_dot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="8sp"
                    android:textColor="@color/widget_text_primary"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_timer_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/widget_text_secondary"
                    android:fontFamily="sans-serif-medium" />

                <Chronometer
                    android:id="@+id/timer_chrono"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/widget_text_primary"
                    android:fontFamily="sans-serif-medium"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_prediction"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/widget_text_secondary"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_since"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginTop="2dp"
                android:textSize="10sp"
                android:textColor="@color/widget_text_since"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>

    <!-- Row 2: Breast L / R buttons (only visible for nursing mums) -->
    <LinearLayout
        android:id="@+id/breast_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/btn_breast_l"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/widget_btn_feed"
            android:gravity="center"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/tv_bl_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="L"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/widget_text_primary" />
            <TextView
                android:id="@+id/tv_bl_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text=""
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/widget_text_secondary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_breast_r"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:background="@drawable/widget_btn_feed"
            android:gravity="center"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/tv_br_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="R"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/widget_text_primary" />
            <TextView
                android:id="@+id/tv_br_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text=""
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="@color/widget_text_secondary" />
        </LinearLayout>
    </LinearLayout>

    <!-- Row 3: Feed, Nappy, Nap/Stop -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:baselineAligned="false">

        <LinearLayout
            android:id="@+id/btn_feed"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:background="@drawable/widget_btn_feed"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tv_feed_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍼"
                android:textSize="18sp" />
            <TextView
                android:id="@+id/tv_feed_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Feed"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/widget_text_primary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_nappy"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="5dp"
            android:background="@drawable/widget_btn_nappy"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🧷"
                android:textSize="18sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nappy"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/widget_text_primary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_nap_stop"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            android:background="@drawable/widget_btn_nap"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:id="@+id/tv_ns_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▶"
                android:textSize="18sp"
                android:textColor="@color/widget_text_primary" />
            <TextView
                android:id="@+id/tv_ns_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nap"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="@color/widget_text_primary" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
