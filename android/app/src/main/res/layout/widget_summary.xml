<?xml version="1.0" encoding="utf-8"?>
<!-- OBubba Home Screen Widget — matches iOS design -->
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="14dp"
    android:background="@drawable/widget_background">

    <!-- Row 1: Baby name -->
    <TextView
        android:id="@+id/tv_baby_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:text="Baby"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#5B4F5F"
        android:fontFamily="sans-serif-medium" />

    <!-- Row 2: Prediction pill (green bg, shows next nap/bed time) -->
    <LinearLayout
        android:id="@+id/prediction_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tv_baby_name"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_prediction"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textSize="13sp"
            android:textColor="#5B7A6B"
            android:background="@drawable/widget_prediction_bg"
            android:padding="8dp"
            android:gravity="center"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/tv_nap_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text=""
            android:textSize="11sp"
            android:textColor="#8B7EC8"
            android:fontFamily="sans-serif-medium" />
    </LinearLayout>

    <!-- Quick action buttons (pinned to bottom) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:gravity="center">

        <Button
            android:id="@+id/btn_log_feed"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Feed"
            android:textSize="12sp"
            android:textColor="#C07088"
            android:background="@drawable/widget_action_bg"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btn_log_nappy"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:text="Nappy"
            android:textSize="12sp"
            android:textColor="#7BA68C"
            android:background="@drawable/widget_action_bg"
            android:textAllCaps="false" />

        <Button
            android:id="@+id/btn_log_sleep"
            android:layout_width="0dp"
            android:layout_height="38dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:text="Nap"
            android:textSize="12sp"
            android:textColor="#8B7EC8"
            android:background="@drawable/widget_action_bg"
            android:textAllCaps="false" />
    </LinearLayout>
</RelativeLayout>
